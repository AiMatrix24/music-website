{
  "permissions": {
    "allow": [
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_Preview__preview_console_logs",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_list",
      "mcp__Claude_in_Chrome__navigate",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_in_Chrome__find",
      "mcp__Claude_in_Chrome__read_console_messages",
      "Bash(nslookup *)",
      "Bash(docker info *)",
      "Bash(vercel logs *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "F=$(node -e \"const j=JSON.parse(require('fs').readFileSync(0,'utf8'));console.log(j.tool_input?.file_path||j.tool_response?.filePath||'')\"); case \"$F\" in *.ts|*.tsx) touch /tmp/opynx-typecheck-needed ;; esac",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f /tmp/opynx-typecheck-needed ] || exit 0; rm -f /tmp/opynx-typecheck-needed; cd \"/c/Users/rsand/Documents/Claude Desk top/music-website\" || exit 0; OUT=$(npm run typecheck 2>&1); EC=$?; if [ $EC -eq 0 ]; then exit 0; fi; node -e \"console.log(JSON.stringify({decision:'block',reason:'TypeScript typecheck failed before stop. Fix these errors first:\\n\\n'+process.argv[1]}))\" \"$(echo \"$OUT\" | tail -50)\"",
            "timeout": 120,
            "statusMessage": "Verifying TypeScript types"
          }
        ]
      }
    ]
  }
}
