# ===== OPYNX Environment Variables =====
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Database ───
DATABASE_URL=postgresql://postgres:password@localhost:5432/opynx
REDIS_URL=redis://localhost:6379

# ─── Search ───
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_master_key

# ─── Auth (NextAuth.js v5) ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ─── OAuth Providers ───
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Samiteon (Fiat Payments) ───
SAMITEON_API_KEY=
SAMITEON_WEBHOOK_SECRET=

# ─── Helio Protocol (Crypto Payments) ───
HELIO_API_KEY=
HELIO_WEBHOOK_SECRET=
HELIO_PLAN_ID_PREMIUM=
HELIO_PLAN_ID_STUDIO=
HELIO_PLAN_ID_BUNDLE=

# ─── Storage (S3/R2) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=opynx-media
AWS_REGION=us-east-1

# ─── Blockchain (Polygon) ───
DEPLOYER_PRIVATE_KEY=
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Deployed Contract Addresses (filled after deployment) ───
PAYMENT_SPLITTER_ADDRESS=
ATTRIBUTION_REGISTRY_ADDRESS=
SUBSCRIPTION_MANAGER_ADDRESS=
USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# ─── Gelato (Gasless Relay) ───
NEXT_PUBLIC_GELATO_API_KEY=
GELATO_TRUSTED_FORWARDER=

# ─── Observability ───
SENTRY_DSN=

# ─── Email ───
RESEND_API_KEY=
