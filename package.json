{
  "name": "opynx",
  "version": "0.1.0",
  "private": true,
  "description": "OPYNX — FanEngage Protocol: Direct-to-Fan Music & Events Platform",
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db",
    "db:seed": "npx tsx packages/db/seed.ts",
    "worker": "npm run worker --workspace=packages/queue",
    "contracts:compile": "npm run compile --workspace=packages/contracts",
    "contracts:test": "npm run test --workspace=packages/contracts",
    "contracts:deploy:testnet": "npm run deploy:testnet --workspace=packages/contracts",
    "contracts:deploy:mainnet": "npm run deploy:mainnet --workspace=packages/contracts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1"
  },
  "dependencies": {
    "bullmq": "^5.73.5",
    "web-push": "^3.6.7"
  }
}
